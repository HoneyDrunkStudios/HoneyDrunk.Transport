<Project>

  <!--
    SonarQube Cloud scoping for HoneyDrunk.Transport.

    Per ADR-0011 D11, sonar settings are passed via <SonarQubeSetting>
    items (NOT a sonar-project.properties file, which conflicts with the
    SonarScanner for .NET).

    Exclusions:
      - SandboxNode is a console sample/demo app (Exe, IsPackable=false),
        not production code. It exists to exercise the transport stack
        end-to-end during development and is intentionally not covered
        by unit tests. Excluding it from coverage prevents 0% sample-app
        coverage from masking the real production-code coverage signal.

      - LoggerMessage.g.cs and other *.g.cs files are generated by source
        generators; their (un)coverage is not actionable.
  -->
  <ItemGroup>
    <SonarQubeSetting Include="sonar.coverage.exclusions">
      <Value>**/HoneyDrunk.Transport.SandboxNode/**,**/*.g.cs</Value>
    </SonarQubeSetting>
    <SonarQubeSetting Include="sonar.exclusions">
      <Value>**/HoneyDrunk.Transport.SandboxNode/**,**/*.g.cs</Value>
    </SonarQubeSetting>
  </ItemGroup>

</Project>
